/* pages/starMap/starMap.wxss */
.star-container {
  width: 100%;
  height: 100vh;
  background-color: #000;
  position: relative;
  overflow: hidden;
}

.star-canvas {
  width: 100%;
  height: 90vh;
  background-color: #000;
}

.control-bar {
  position: fixed;
  bottom: 20rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 10;
}

.reset-btn {
  background: rgba(30, 40, 60, 0.8);
  color: white;
  border-radius: 50rpx;
  width: 200rpx;
  font-size: 28rpx;
  backdrop-filter: blur(8px);
}

.star-tip {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #8e9aaf;
  background: rgba(0,0,0,0.5);
  padding: 10rpx;
}