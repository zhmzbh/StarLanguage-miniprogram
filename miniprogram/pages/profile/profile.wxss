/* pages/profile/profile.wxss */
.container {
  padding: 40rpx 30rpx;
  background-color: #0a1128;
  min-height: 100vh;
}

.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #4d9fff;
  margin-bottom: 20rpx;
}

.nickname {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.login-btn {
  background: #2a5f8a;
  color: white;
  border-radius: 60rpx;
  width: 300rpx;
  font-size: 28rpx;
}

.menu-list {
  background: #16213e;
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #0f1a2f;
  font-size: 32rpx;
  color: #fff;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #8e9aaf;
  font-size: 28rpx;
}

.footer {
  text-align: center;
  margin-top: 100rpx;
  color: #6b7a8a;
  font-size: 24rpx;
}
/* 添加昵称输入框样式 */
.nickname-input {
  background: #16213e;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
  color: #fff;
  font-size: 28rpx;
  width: 400rpx;
  text-align: center;
}

.save-btn {
  background: linear-gradient(135deg, #2a5f8a, #1d3e5a);
  color: white;
  border-radius: 60rpx;
  font-size: 28rpx;
  width: 300rpx;
  height: 70rpx;
  line-height: 70rpx;
  margin-top: 20rpx;
}